<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bachprog.LogInMechanicWindow">
   <children>
      <Button layoutX="14.0" layoutY="360.0" mnemonicParsing="false" onAction="#OpenMainWindow" text="Home" />
      <Label alignment="CENTER" layoutX="232.0" layoutY="29.0" prefHeight="39.0" prefWidth="136.0" text="Dear Machanic,">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label alignment="CENTER" layoutX="68.0" layoutY="85.0" prefHeight="50.0" prefWidth="464.0" text="Kindly enter your name and password to open your file" textAlignment="CENTER">
         <font>
            <Font name="System Italic" size="14.0" />
         </font>
      </Label>
      <TextField fx:id="mechanicNameLabel" layoutX="200.0" layoutY="154.0" prefHeight="26.0" prefWidth="199.0" promptText="Enter your name" />
      <Button fx:id="mechanicLogInButton" layoutX="276.0" layoutY="312.0" mnemonicParsing="false" onAction="#submit" text="LogIn" />
      <Label fx:id="alertLabel" alignment="CENTER" layoutX="86.0" layoutY="282.0" prefHeight="18.0" prefWidth="427.0" text="Click on LogIn button once you entered your name and password" textAlignment="CENTER">
         <font>
            <Font name="System Bold Italic" size="12.0" />
         </font>
      </Label>
      <CheckBox fx:id="showThePasswordButton" layoutX="200.0" layoutY="251.0" mnemonicParsing="false" onAction="#showThePassword" prefHeight="18.0" prefWidth="135.0" text="show the password">
         <font>
            <Font name="System Bold Italic" size="12.0" />
         </font>
      </CheckBox>
      <TextField fx:id="unhiddenPassword" layoutX="200.0" layoutY="200.0" prefHeight="26.0" prefWidth="199.0" promptText="Enter your password" />
      <PasswordField fx:id="mechanicPasswordLabel" layoutX="200.0" layoutY="200.0" prefHeight="26.0" prefWidth="199.0" promptText="Enter your password" />
   </children>
</AnchorPane>
