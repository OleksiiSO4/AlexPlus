<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="514.0" prefWidth="380.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bachprog.OrderRequest">
   <children>
      <DatePicker fx:id="dateRequest" layoutX="159.0" layoutY="49.0" prefHeight="26.0" prefWidth="211.0" />
      <Label fx:id="greetingLabel" layoutX="109.0" layoutY="14.0" prefHeight="18.0" prefWidth="161.0" text="Dear,  ">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>
      <Label layoutX="8.0" layoutY="52.0" prefHeight="20.0" prefWidth="147.0" text="Chose the date:">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>
      <Label layoutX="8.0" layoutY="91.0" prefHeight="20.0" prefWidth="162.0" text="Enter make of your car:">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>
      <TextField fx:id="makeOfCarRequested" layoutX="190.0" layoutY="90.0" />
      <Label layoutX="8.0" layoutY="126.0" prefHeight="20.0" prefWidth="162.0" text="Enter model of your car:">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>
      <TextField fx:id="modelOfCarRequested" layoutX="190.0" layoutY="125.0" />
      <Label layoutX="8.0" layoutY="170.0" prefHeight="20.0" prefWidth="180.0" text="Chose the type of service:">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>
      <ChoiceBox fx:id="requestedServiceType" layoutX="189.0" layoutY="166.0" prefWidth="150.0" />
      <Label fx:id="describeIssueLabel" layoutX="8.0" layoutY="201.0" prefHeight="20.0" prefWidth="162.0" text="Describe your issue:">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>
      <TextField fx:id="requestedIssue" layoutX="151.0" layoutY="200.0" prefHeight="26.0" prefWidth="205.0" />
      <Button fx:id="addButton" layoutX="169.0" layoutY="244.0" mnemonicParsing="false" onAction="#addRequestToDB" text="Add" />
      <ListView fx:id="repairRequests" layoutX="8.0" layoutY="277.0" prefHeight="200.0" prefWidth="360.0" />
      <Button fx:id="deleteButton" layoutX="165.0" layoutY="483.0" mnemonicParsing="false" onAction="#removeRequestFromDB" text="Delete" />
   </children>
</AnchorPane>
